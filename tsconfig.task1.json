{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["src/cli.ts", "src/pilot/**/*.ts"]
}
